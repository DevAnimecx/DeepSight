{
  "version": "1.0.0",
  "description": "DeepSight risk scoring matrix for vulnerability severity",
  "scores": {
    "critical": {
      "range": [9, 10],
      "description": "Immediate exploitation possible, data breach or system compromise",
      "examples": ["SQL injection with data access", "Hardcoded production secrets", "Authentication bypass"],
      "action": "Must fix before merge",
      "model": "opus-4.7",
      "time_budget": "5 minutes"
    },
    "high": {
      "range": [7, 8],
      "description": "Exploitation requires conditions but significant impact",
      "examples": ["Stored XSS in user profile", "IDOR on sensitive resources", "Missing authorization checks"],
      "action": "Must fix before merge",
      "model": "opus-4.7",
      "time_budget": "3 minutes"
    },
    "medium": {
      "range": [4, 6],
      "description": "Security gap with limited exploitability or impact",
      "examples": ["Missing input validation (non-exploitable context)", "Weak cryptography", "Missing security headers"],
      "action": "Fix in next sprint",
      "model": "haiku-4",
      "time_budget": "2 minutes"
    },
    "low": {
      "range": [1, 3],
      "description": "Defense-in-depth, best practice, or cosmetic",
      "examples": ["Missing rate limiting on low-risk endpoint", "Verbose error messages", "Missing CSP"],
      "action": "Address when convenient",
      "model": "haiku-4",
      "time_budget": "1 minute"
    }
  },
  "factors": {
    "exploitability": {
      "weight": 0.4,
      "levels": {
        "immediate": 10,
        "one_condition": 7,
        "multiple_conditions": 4,
        "theoretical": 2
      }
    },
    "impact": {
      "weight": 0.35,
      "levels": {
        "full_compromise": 10,
        "data_breach": 8,
        "service_disruption": 6,
        "information_disclosure": 4,
        "cosmetic": 2
      }
    },
    "scope": {
      "weight": 0.15,
      "levels": {
        "all_users": 10,
        "many_users": 7,
        "some_users": 4,
        "single_user": 2
      }
    },
    "remediation_effort": {
      "weight": 0.1,
      "levels": {
        "trivial": 10,
        "minor_refactor": 7,
        "significant_change": 4,
        "architectural_change": 2
      }
    }
  },
  "aggregation": {
    "method": "weighted_average",
    "formula": "sum(score * weight) for each factor"
  }
}
